# Required for local --baseline, vercel dev, and production /api/snapshot
SUPABASE_URL=
SUPABASE_KEY=           # service_role key (not anon) — also set in Vercel project env

# Optional Vercel API tuning (see docs/VERCEL_DEPLOY.md)
# SNAPSHOT_CACHE_SECONDS=0
# SNAPSHOT_DEBUG=false
ANTHROPIC_API_KEY=
BREVO_API_KEY=
BREVO_MCP_TOKEN=        # MCP-capable key for Cursor (https://mcp.brevo.com/v1/brevo/mcp)
BEEHIIV_API_KEY=
EMAILOCTOPUS_API_KEY=
ALERT_EMAIL=
FROM_EMAIL=
FROM_NAME=

# Operational broadcasts (legal / incident) — see docs/OPERATIONAL_EMAIL_RUNBOOK.md
# Resend Pro (~$20/mo) backup when SES sandbox; same key as lifecycle
RESEND_API_KEY=
RESEND_OPERATIONAL_AUDIENCE_ID=
LOOPS_API_KEY=           # Lifecycle fallback — not legal/outage
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=
