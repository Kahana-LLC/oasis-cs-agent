# Required for local --baseline, vercel dev, and production /api/snapshot
SUPABASE_URL=
SUPABASE_KEY=           # service_role key (not anon) — also set in Vercel project env

# Optional Vercel API tuning (see docs/VERCEL_DEPLOY.md)
# SNAPSHOT_CACHE_SECONDS=0
# SNAPSHOT_DEBUG=false
ANTHROPIC_API_KEY=
BREVO_API_KEY=             # Brevo → SMTP & API → API keys (v3 key)
BREVO_TEMPLATE_ID_WELCOME= # Brevo SMTP template id for "Oasis Welcome" — scripts/list_brevo_smtp_templates.py
BREVO_TEMPLATE_ID_ACTIVATION_NUDGE= # "Oasis Activation Nudge" — scripts/list_brevo_smtp_templates.py
BREVO_TEMPLATE_ID_ACTIVATION_CS_CALENDAR= # "Oasis Activation CS Calendar"
BREVO_TEMPLATE_ID_NPS_DAY3= # "Oasis NPS" — template id 56
BREVO_TEMPLATE_ID_PMF_DAY10= # "Oasis PMF" — template id 57
# Phase 2+ lifecycle (Supabase Edge) — create templates in Brevo, then set ids
BREVO_TEMPLATE_ID_LIMIT_HITTER_D0=
BREVO_TEMPLATE_ID_LIMIT_HITTER_D7=
BREVO_TEMPLATE_ID_UPGRADE_THANK_YOU=
BREVO_TEMPLATE_ID_CANCELLED_D0=
BREVO_TEMPLATE_ID_CANCELLED_D14=
BREVO_TEMPLATE_ID_AT_RISK_D0=
BREVO_TEMPLATE_ID_AT_RISK_D7=
BREVO_TEMPLATE_ID_AT_RISK_D14=
BREVO_TEMPLATE_ID_AT_RISK_D21=
BREVO_TEMPLATE_ID_DEAD_D0=
BREVO_TEMPLATE_ID_DEAD_D14=
BREVO_TEMPLATE_ID_RETURN_REINFORCEMENT=
BREVO_TEMPLATE_ID_ENTERPRISE_FOUNDER=
BREVO_TEMPLATE_ID_ENTERPRISE_EXPANSION=
LIFECYCLE_SENDER_EMAIL=    # Verified Brevo sender (fallback: FROM_EMAIL)
LIFECYCLE_SENDER_NAME="Adam from Oasis"
BREVO_LIFECYCLE_LIST_ID=   # Numeric list id for "Oasis Lifecycle" — legacy automation only
# BREVO_PHASE1_QA_LIST_ID=  # Deprecated alias; still read if BREVO_LIFECYCLE_LIST_ID unset
BREVO_MCP_TOKEN=        # MCP-capable key for Cursor (https://mcp.brevo.com/v1/brevo/mcp)
BEEHIIV_API_KEY=
EMAILOCTOPUS_API_KEY=
ALERT_EMAIL=
FROM_EMAIL=
FROM_NAME=

# Operational broadcasts (legal / incident) — see docs/OPERATIONAL_EMAIL_RUNBOOK.md
# Resend Pro (~$20/mo) backup when SES sandbox; same key as lifecycle
RESEND_API_KEY=
RESEND_OPERATIONAL_AUDIENCE_ID=
LOOPS_API_KEY=           # Lifecycle fallback — not legal/outage
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=
