{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": null,
  "buildCommand": "python3 reporting/build_static_site.py",
  "outputDirectory": "public",
  "framework": null,
  "build": {
    "env": {
      "PYTHON_VERSION": "3.12"
    }
  },
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "excludeFiles": "{.venv/**,**/__pycache__/**,public/**,reporting/sql_export.json}"
    }
  }
}
